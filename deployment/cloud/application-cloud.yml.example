# Reference only. The real backend cloud profile lives in:
# backend/src/main/resources/application-cloud.yml
#
# This example documents the expected environment variable mapping.
# Do not put real secrets in this file.

spring:
  profiles:
    active: cloud
  datasource:
    url: jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
    username: ${DB_USER}
    password: ${DB_PASSWORD}
  jpa:
    hibernate:
      ddl-auto: validate
  flyway:
    enabled: true

app:
  auth:
    jwt-secret: ${JWT_SECRET}
    x-user-id-fallback-enabled: false
  dev-tools:
    role-switcher-enabled: false
  seed:
    safe-metadata-enabled: true
    default-users-enabled: false
    demo-data-enabled: false
    membership-supplement-enabled: false
    production-bootstrap-enabled: false

features:
  printing: true
  kds: false

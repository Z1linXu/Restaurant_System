# Restaurant POS server deployment environment.
# Copy to .env on the server and fill real values there.
# Never commit the filled .env file.

# Public domain already pointing to the Tencent Cloud server public IP.
DOMAIN=pos.example.com
LETSENCRYPT_EMAIL=owner@example.com
ENABLE_HTTPS=true

# Public ports. Keep these as 80/443 for Let's Encrypt HTTP-01 validation.
HTTP_PORT=80
HTTPS_PORT=443

# Docker image names built locally by docker compose.
BACKEND_IMAGE=restaurant-pos-backend:local
FRONTEND_IMAGE=restaurant-pos-frontend:local
POSTGRES_IMAGE_TAG=16-alpine
CERTBOT_IMAGE_TAG=latest

# Spring Boot cloud profile.
SPRING_PROFILES_ACTIVE=cloud

# PostgreSQL runs as the docker compose db service.
DB_NAME=restaurant_pos
DB_USER=restaurant_pos
DB_PASSWORD=replace-with-a-strong-database-password

# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-strong-jwt-secret

# Optional runtime settings.
TZ=America/Toronto
JAVA_OPTS="-Xms256m -Xmx1024m"
VITE_APP_BUILD_VERSION=server
BACKUP_DIR=./data/backups

# update.sh can pull code before rebuilding when this is true.
UPDATE_GIT_PULL=false
